# AzProud Production Environment Configuration
# Copy this file to .env.production and fill in the actual values
# Do NOT commit .env.production to version control

################################################################################
# Supabase Configuration
################################################################################
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here-eyJ0eXAiOiJKV1QiLCJhbGc...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-eyJ0eXAiOiJKV1QiLCJhbGc...

################################################################################
# Azure OpenAI Configuration
################################################################################
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

################################################################################
# Application Configuration
################################################################################
NODE_ENV=production
VITE_API_URL=https://proud.azab.services/api
APP_PORT=3000
APP_HOST=0.0.0.0

################################################################################
# Daftra Integration (Optional)
################################################################################
DAFTRA_API_KEY=your-daftra-api-key
DAFTRA_DOMAIN=your-company.daftra.com
DAFTRA_WEBHOOK_SECRET=your-webhook-secret

################################################################################
# Bot Gateway Integration (Optional)
################################################################################
BOT_GATEWAY_API_KEY=your-bot-gateway-key
BOT_GATEWAY_ENDPOINT=https://api.botgateway.com/v1

################################################################################
# Security
################################################################################
# Session encryption
SESSION_SECRET=generate-a-random-256-bit-secret-key-here
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

################################################################################
# Email Configuration (for notifications)
################################################################################
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@azab.services
EMAIL_SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM_NAME=AzProud
EMAIL_FROM_ADDRESS=noreply@azab.services

################################################################################
# Logging
################################################################################
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=/home/ubuntu/azproud/logs

################################################################################
# Database Backup
################################################################################
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

################################################################################
# Monitoring & Analytics
################################################################################
SENTRY_DSN=
AMPLITUDE_API_KEY=
DATADOG_API_KEY=

################################################################################
# Domain Configuration
################################################################################
PRIMARY_DOMAIN=proud.azab.services
ALLOWED_ORIGINS=https://proud.azab.services,https://www.proud.azab.services

################################################################################
# Feature Flags
################################################################################
FEATURE_AI_REVIEW=true
FEATURE_INTEGRATIONS=true
FEATURE_EDGE_FUNCTIONS=true
FEATURE_ANALYTICS=true
